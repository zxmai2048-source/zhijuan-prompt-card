{
  "name": "zhijuan-prompt-card",
  "version": "0.3.3",
  "description": "Local-first image-to-prompt Chrome extension.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/papperrollinggery/zhijuan-prompt-card.git"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "check:api-options": "tsx scripts/check-api-options.ts",
    "check:json-repair": "tsx scripts/check-json-repair.ts",
    "check:prompt-goal": "node scripts/check-prompt-goal.mjs",
    "check:storage": "tsx scripts/check-storage.ts",
    "check:url": "tsx scripts/check-url.ts",
    "e2e:bilibili": "node scripts/e2e-bilibili-extension.mjs",
    "test:real-extension": "node scripts/manual-real-extension-test.mjs",
    "test:real-json": "tsx scripts/real-image-json-readiness-audit.ts",
    "test:real-structure": "tsx scripts/real-image-structural-audit.ts",
    "smoke:history": "node scripts/smoke-visual-history.mjs",
    "release:check": "node scripts/check-release.mjs",
    "release:package": "node scripts/package-release.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3"
  }
}
